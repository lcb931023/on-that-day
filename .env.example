# SQLite DSN used by both server and dbsync.
# Use a file path for persistence, or ":memory:" for tests.
SQLITE_DSN=on-that-day.db

# Server listen address.
SERVER_ADDR=:8080

# Path to the original on-that-day/site/data directory (used by dbsync).
DATA_DIR=../on-that-day/site/data

# Path to the static site directory (used by server to serve HTML/JS/CSS).
# Default is the built React output. Use ../on-that-day/site for the original static site.
SITE_DIR=frontend/dist

# Set to true to enable GORM SQL logging.
DEBUG=false
